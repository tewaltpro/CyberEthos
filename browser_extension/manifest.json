{
  "manifest_version": 3,
  "name": "CyberEthos Reflect",
  "version": "1.0.0",
  "description": "A brief, thoughtful pause before you upload or download a file.",
  "permissions": ["downloads", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_upload.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "CyberEthos Reflect"
  }
}
